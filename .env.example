# Keep the real value outside Git and outside browser code.
OPENAI_API_KEY=
VES_OPENAI_MODEL=gpt-5.6
VES_PUBLIC_BASE_URL=https://verifiedengineeringstudio.schares-timo.de

# Public live-review cost guard. Set the daily limit to 0 for an emergency stop.
VES_CLIENT_LIVE_REVIEW_LIMIT=3
VES_CLIENT_WINDOW_SECONDS=3600
VES_DAILY_LIVE_REVIEW_LIMIT=20
VES_MAX_CONCURRENT_LIVE_REVIEWS=1
VES_REVIEW_CACHE_TTL_SECONDS=604800
VES_OPENAI_MAX_OUTPUT_TOKENS=1800
VES_OPENAI_TIMEOUT_SECONDS=45

# Production sets this through systemd's private StateDirectory. Local development uses .state/.
# VES_STATE_DB=.state/review-guard.sqlite3
# Optional for multi-instance deployments; a private persistent secret is generated if omitted.
# VES_RATE_LIMIT_SECRET=
